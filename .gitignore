## .gitignore for cloudsmith-module-hello

# Build outputs
bin/
obj/
publish/

# NuGet packages
*.nupkg
*.snupkg
.nuget/

# Rider / VS / VS Code
.idea/
.vs/
*.user
*.suo
*.userprefs
.vscode/
*.launch

# OS
.DS_Store
Thumbs.db

# Secrets — never commit
*.env
.env.*
appsettings.Production.json
appsettings.local.json
secrets.json
nuget.config.local

# Test results
TestResults/
coverage/
*.trx
*.coveragexml
